# =============================================================================
# Backend env config — все обязательные переменные для запуска (env-required).
# Скопируйте в .env и подставьте свои значения.
# =============================================================================

ENV=local
CONFIG_PATH=./configs/local.json

# -----------------------------------------------------------------------------
# Postgres
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=9081
POSTGRES_USER=telephony
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_DATABASE=telephony
POSTGRES_IS_DEBUG=true
POSTGRES_REQUEST_TIMEOUT=3s

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=9082
REDIS_PASSWORD=your-redis-password
REDIS_DB=0

# -----------------------------------------------------------------------------
# Auth (cookie, JWT TTL, Redis ключи, ссылка подтверждения)
# -----------------------------------------------------------------------------
REFRESH_TOKEN_COOKIE_NAME=refresh_token
REFRESH_TOKEN_COOKIE_MAX_AGE=604800
REFRESH_TOKEN_COOKIE_SECURE=false
# Время жизни access-токена (сек). 86400 = 24 ч — сессия не сбрасывается при краткой неактивности.
ACCESS_TOKEN_TTL_SEC=86400
REFRESH_TOKEN_TTL_SEC=604800
TOKEN_REDIS_KEY_PREFIX=auth:refresh:
AUTH_LINK_BASE_URL=http://localhost:8081
AUTH_LINK_TTL_SEC=600
AUTH_LINK_MAX_ATTEMPTS=5
AUTH_LINK_REDIS_KEY_PREFIX=auth:link:

# -----------------------------------------------------------------------------
# Auth env (секреты)
# -----------------------------------------------------------------------------
JWT_SECRET=your-jwt-secret-change-in-production
OAUTH_GOOGLE_CLIENT_SECRET=your-google-client-secret
OAUTH_APPLE_TEAM_ID=your-apple-team-id
OAUTH_APPLE_KEY_ID=your-apple-key-id
# Один из двух: содержимое .p8 или путь к файлу
# OAUTH_APPLE_PRIVATE_KEY_PEM=
# OAUTH_APPLE_PRIVATE_KEY_PATH=./path/to/AuthKey_XXXXX.p8

# -----------------------------------------------------------------------------
# OAuth URLs (Google / Apple)
# -----------------------------------------------------------------------------
OAUTH_BACKEND_BASE_URL=http://localhost:8081
OAUTH_STATE_REDIS_KEY_PREFIX=auth:oauth:state:
OAUTH_STATE_TTL_SEC=600
OAUTH_FRONTEND_SUCCESS_URL=http://localhost:5173
OAUTH_FRONTEND_ERROR_URL=http://localhost:5173
OAUTH_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
OAUTH_GOOGLE_REDIRECT_PATH=/v1/auth/google/callback
OAUTH_GOOGLE_USERINFO_URL=https://www.googleapis.com/oauth2/v2/userinfo
OAUTH_APPLE_CLIENT_ID=com.example.app
OAUTH_APPLE_REDIRECT_PATH=/v1/auth/apple/callback
OAUTH_APPLE_AUTH_URL=https://appleid.apple.com/auth/authorize
OAUTH_APPLE_JWKS_URL=https://appleid.apple.com/auth/keys
OAUTH_APPLE_ISSUER=https://appleid.apple.com

# -----------------------------------------------------------------------------
# Storage (Yandex Object Storage / S3)
# -----------------------------------------------------------------------------
STORAGE_ACCESS_KEY_ID=your-storage-access-key
STORAGE_SECRET_ACCESS_KEY=your-storage-secret-key
STORAGE_BUCKET=your-bucket
STORAGE_REGION=ru-central1
STORAGE_ENDPOINT=https://storage.yandexcloud.net
STORAGE_AVATAR_PREFIX=avatars
STORAGE_PUBLIC_BASE_URL=https://storage.yandexcloud.net/your-bucket

# -----------------------------------------------------------------------------
# Email (SMTP)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=App <noreply@example.com>
